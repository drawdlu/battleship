    "@eslint/js": "^10.0.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.5.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.5",
    "jest": "^30.4.1",
    "prettier": "3.8.3",
